  m_Script: {fileID: 11500000, guid: d01fd2d64a9249049aaa77d5c12a82fe, type: 3}
  m_Name: Question 18
  m_EditorClassIdentifier: 
  questionText: What is the correct way to heat the glass tube in the flame?
  referenceImage: {fileID: 0}
  explanationText: The cut end of the glass tube should be warmed in the flame while
    rotating it back and forth until the edge is rounded off. This provides uniform
    heating for proper rounding of the edge.
  options:
  - Keep rotating it back and forth
  - Keep it fixed at the same position
  - Keep shaking the glass tube
  - 'Take the glass tube out from the flame every few seconds '
  correctOptionIndex: 0
